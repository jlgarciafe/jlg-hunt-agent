# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Anthropic (required for scoring) ─────────────────────────────────────────
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (required for persistence) ──────────────────────────────────────
# Get at: https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGc...          # service_role key (keep secret)
SUPABASE_ANON_KEY=eyJhbGc...     # anon key (safe for dashboard)

# ── Telegram (required for notifications) ─────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Message @userinfobot on Telegram → copy your Chat ID
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=987654321

# ── Adzuna (required for job search) ──────────────────────────────────────────
# Register free at: https://developer.adzuna.com/signup
ADZUNA_APP_ID=xxxxxxxx
ADZUNA_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
